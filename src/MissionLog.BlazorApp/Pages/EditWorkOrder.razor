@page "/workorders/{Id:int}/edit"
@inject ApiService Api
@inject AuthStateService Auth
@inject NavigationManager Nav

<PageTitle>MissionLog — Edit WO-@Id.ToString("D4")</PageTitle>

@if (_loading)
{
    <div class="ml-loading"><div class="ml-spinner"></div> LOADING...</div>
}
else if (_wo == null)
{
    <div class="ml-empty">
        <div class="ml-empty-icon">⚠</div>
        <div class="ml-empty-text">WORK ORDER NOT FOUND</div>
    </div>
}
else if (!CanEdit)
{
    <div class="ml-empty">
        <div class="ml-empty-icon">🔒</div>
        <div class="ml-empty-text">YOU DO NOT HAVE PERMISSION TO EDIT THIS WORK ORDER</div>
    </div>
}
else
{
    <div class="ml-page-header">
        <div class="ml-breadcrumb">
            <span @onclick='() => Nav.NavigateTo("/workorders")' style="cursor:pointer;text-decoration:underline">
                // WORK ORDERS
            </span>
            &nbsp;/
            <span @onclick='() => Nav.NavigateTo($"/workorders/{Id}")' style="cursor:pointer;text-decoration:underline">
                WO-@Id.ToString("D4")
            </span>
            &nbsp;/ EDIT
        </div>
        <div class="ml-page-title">Edit Work Order</div>
        <div class="ml-page-sub">
            Modifying WO-@Id.ToString("D4") — Status:
            @StatusBadge(_wo.Status)
            @if (_wo.Status != WorkOrderStatus.Draft)
            {
                <span class="ml-mono ml-text-amber" style="font-size:11px;margin-left:8px">
                    ⚠ Only draft orders can be fully revised. Metadata edits still allowed.
                </span>
            }
        </div>
    </div>

    <div style="max-width:680px">
        <div class="ml-card">

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="ml-alert ml-alert-error">⚠ @_error</div>
            }
            @if (!string.IsNullOrEmpty(_success))
            {
                <div class="ml-alert ml-alert-success">✓ @_success</div>
            }

            <!-- Changed fields indicator -->
            @if (_isDirty)
            {
                <div style="display:flex;align-items:center;gap:8px;margin-bottom:16px;
                            padding:8px 12px;background:rgba(245,158,11,0.08);
                            border:1px solid rgba(245,158,11,0.25);border-radius:6px">
                    <span style="color:var(--ml-amber);font-size:12px">●</span>
                    <span class="ml-mono ml-text-amber" style="font-size:11px;letter-spacing:0.05em">
                        UNSAVED CHANGES
                    </span>
                </div>
            }

            <div class="ml-form-group">
                <label class="ml-label">Work Order Title *</label>
                <input class="ml-input" @bind="_title" @oninput="MarkDirty"
                       placeholder="e.g. Replace hydraulic actuator on Bay 4" />
            </div>

            <div class="ml-form-group">
                <label class="ml-label">System / Subsystem *</label>
                <select class="ml-input ml-select" @bind="_system" @oninput="MarkDirty">
                    <option value="">— Select System —</option>
                    <option>Avionics</option>
                    <option>Propulsion</option>
                    <option>Hydraulics</option>
                    <option>Life Support</option>
                    <option>Navigation</option>
                    <option>Communications</option>
                    <option>Structural</option>
                    <option>Power Systems</option>
                    <option>Thermal Control</option>
                    <option>Other</option>
                </select>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
                <div class="ml-form-group">
                    <label class="ml-label">Priority *</label>
                    <select class="ml-input ml-select" @bind="_priority" @oninput="MarkDirty">
                        <option value="@Priority.Low">⚪ Low</option>
                        <option value="@Priority.Medium">🟡 Medium</option>
                        <option value="@Priority.High">🟠 High</option>
                        <option value="@Priority.Critical">🔴 Critical</option>
                    </select>
                </div>
                <div class="ml-form-group">
                    <label class="ml-label">Due Date</label>
                    <input class="ml-input" type="date" @bind="_dueDate" @oninput="MarkDirty" />
                </div>
            </div>

            <!-- Assignee — Supervisors/Admins only -->
            @if (Auth.CurrentUser?.Role is "Supervisor" or "Admin")
            {
                <div class="ml-form-group">
                    <label class="ml-label">Assigned To</label>
                    @if (_users == null)
                    {
                        <div class="ml-mono ml-text-muted" style="font-size:11px;padding:8px 0">
                            Loading users...
                        </div>
                    }
                    else
                    {
                        <select class="ml-input ml-select" @bind="_assignedToUserId" @oninput="MarkDirty">
                            <option value="">— Unassigned —</option>
                            @foreach (var user in _users)
                            {
                                <option value="@user.Id">@user.Username (@user.Role)</option>
                            }
                        </select>
                    }
                </div>
            }

            <div class="ml-form-group">
                <label class="ml-label">Description *</label>
                <textarea class="ml-textarea" @bind="_description" @oninput="MarkDirty"
                          style="min-height:140px"
                          placeholder="Describe the issue, required work, safety concerns, parts needed...">
                </textarea>
            </div>

            <hr class="ml-divider" />

            <!-- Diff summary -->
            @if (_changes.Any())
            {
                <div style="margin-bottom:16px">
                    <div class="ml-label" style="margin-bottom:8px">CHANGES TO BE SAVED</div>
                    <div style="display:flex;flex-direction:column;gap:4px">
                        @foreach (var change in _changes)
                        {
                            <div style="font-family:var(--ml-mono);font-size:11px;
                                        display:flex;gap:8px;align-items:baseline">
                                <span style="color:var(--ml-text-muted);min-width:100px">@change.Field</span>
                                <span style="color:var(--ml-red);text-decoration:line-through">@change.From</span>
                                <span style="color:var(--ml-text-muted)">→</span>
                                <span style="color:var(--ml-green)">@change.To</span>
                            </div>
                        }
                    </div>
                </div>
                <hr class="ml-divider" />
            }

            <div style="display:flex;gap:10px;justify-content:space-between;align-items:center">
                <button class="ml-btn ml-btn-ghost"
                        @onclick='() => Nav.NavigateTo($"/workorders/{Id}")'>
                    ← CANCEL
                </button>
                <div style="display:flex;gap:10px">
                    <button class="ml-btn ml-btn-ghost" @onclick="ResetForm" disabled="@(!_isDirty)">
                        ↺ RESET
                    </button>
                    <button class="ml-btn ml-btn-primary" @onclick="Save"
                            disabled="@(_saving || !_isDirty)">
                        @if (_saving)
                        {
                            <span class="ml-spinner"></span>
                            <span>SAVING...</span>
                        }
                        else
                        {
                            <span>💾 SAVE CHANGES</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    WorkOrderDto? _wo;
    List<UserDto>? _users;
    bool _loading = true, _saving, _isDirty;
    string _error = "", _success = "";

    // Form fields
    string _title = "", _system = "", _description = "";
    Priority _priority = Priority.Medium;
    DateTime? _dueDate;
    int? _assignedToUserId;

    // Snapshot for dirty detection + diff
    string _origTitle = "", _origSystem = "", _origDescription = "";
    Priority _origPriority;
    DateTime? _origDueDate;
    int? _origAssignedToUserId;

    record ChangeItem(string Field, string From, string To);
    List<ChangeItem> _changes = new();

    bool CanEdit => _wo != null &&
        (_wo.CreatedBy == Auth.CurrentUser?.Username ||
         Auth.CurrentUser?.Role is "Supervisor" or "Admin");

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _wo = await Api.GetWorkOrderAsync(Id);
            if (_wo != null)
            {
                PopulateForm();
                TakeSnapshot();
            }

            if (Auth.CurrentUser?.Role is "Supervisor" or "Admin")
                _users = await Api.GetUsersAsync();
        }
        catch { _error = "Failed to load work order."; }
        finally { _loading = false; }
    }

    void PopulateForm()
    {
        _title            = _wo!.Title;
        _system           = _wo.System;
        _description      = _wo.Description;
        _priority         = _wo.Priority;
        _dueDate          = _wo.DueDate;
        _assignedToUserId = _users?.FirstOrDefault(u => u.Username == _wo.AssignedTo)?.Id;
    }

    void TakeSnapshot()
    {
        _origTitle            = _title;
        _origSystem           = _system;
        _origDescription      = _description;
        _origPriority         = _priority;
        _origDueDate          = _dueDate;
        _origAssignedToUserId = _assignedToUserId;
    }

    void MarkDirty(ChangeEventArgs _)
    {
        _isDirty = true;
        BuildChanges();
    }

    void BuildChanges()
    {
        _changes.Clear();
        if (_title       != _origTitle)       _changes.Add(new("Title",       Truncate(_origTitle),       Truncate(_title)));
        if (_system      != _origSystem)      _changes.Add(new("System",      _origSystem,                _system));
        if (_priority    != _origPriority)    _changes.Add(new("Priority",    _origPriority.ToString(),   _priority.ToString()));
        if (_description != _origDescription) _changes.Add(new("Description", "...",                      "updated"));
        if (_dueDate     != _origDueDate)     _changes.Add(new("Due Date",    _origDueDate?.ToString("MM/dd/yyyy") ?? "none", _dueDate?.ToString("MM/dd/yyyy") ?? "none"));
        if (_assignedToUserId != _origAssignedToUserId)
        {
            var fromName = _users?.FirstOrDefault(u => u.Id == _origAssignedToUserId)?.Username ?? "Unassigned";
            var toName   = _users?.FirstOrDefault(u => u.Id == _assignedToUserId)?.Username ?? "Unassigned";
            _changes.Add(new("Assigned To", fromName, toName));
        }
    }

    void ResetForm()
    {
        _title            = _origTitle;
        _system           = _origSystem;
        _description      = _origDescription;
        _priority         = _origPriority;
        _dueDate          = _origDueDate;
        _assignedToUserId = _origAssignedToUserId;
        _isDirty          = false;
        _changes.Clear();
        _error            = "";
        _success          = "";
    }

    async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_title))       { _error = "Title is required.";       return; }
        if (string.IsNullOrWhiteSpace(_system))      { _error = "System is required.";      return; }
        if (string.IsNullOrWhiteSpace(_description)) { _error = "Description is required."; return; }

        _saving = true; _error = "";
        try
        {
            var dto = new UpdateWorkOrderDto(_title, _description, _priority, _system, _dueDate, _assignedToUserId);
            var result = await Api.UpdateWorkOrderAsync(Id, dto);
            if (result != null)
            {
                _wo      = result;
                _success = $"Work order saved — {_changes.Count} field{(_changes.Count != 1 ? "s" : "")} updated.";
                _isDirty = false;
                _changes.Clear();
                TakeSnapshot();
            }
            else
            {
                _error = "Save failed — check your permissions and API connection.";
            }
        }
        catch (Exception ex) { _error = $"Error: {ex.Message}"; }
        finally { _saving = false; }
    }

    static string Truncate(string s, int max = 40) =>
        s.Length <= max ? s : s[..max] + "…";

    RenderFragment StatusBadge(WorkOrderStatus s) => s switch
    {
        WorkOrderStatus.Draft       => @<span class="ml-badge ml-badge-draft">Draft</span>,
        WorkOrderStatus.Submitted   => @<span class="ml-badge ml-badge-submitted">Submitted</span>,
        WorkOrderStatus.UnderReview => @<span class="ml-badge ml-badge-review">Under Review</span>,
        WorkOrderStatus.Approved    => @<span class="ml-badge ml-badge-approved">Approved</span>,
        WorkOrderStatus.InProgress  => @<span class="ml-badge ml-badge-progress">In Progress</span>,
        WorkOrderStatus.Completed   => @<span class="ml-badge ml-badge-completed">Completed</span>,
        WorkOrderStatus.Rejected    => @<span class="ml-badge ml-badge-rejected">Rejected</span>,
        _ => @<span class="ml-badge ml-badge-draft">@s</span>
    };
}
